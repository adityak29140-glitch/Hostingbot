# --- STOP PANEL CALLBACK HANDLER ---
@bot.callback_query_handler(func=lambda call: True)
def handle_query(call):
    user_id = call.from_user.id
    if call.data.startswith("manage_"):
        bot_id = call.data.split("_")[1]
        b_data = user_sessions.get(user_id, {}).get(bot_id)
        if b_data:
            markup = types.InlineKeyboardMarkup(row_width=1)
            markup.add(types.InlineKeyboardButton("🛑 STOP BOT", callback_data=f"stop_{bot_id}"))
            bot.edit_message_text(f"🛠 <b>𝐌𝐀𝐍𝐀𝐆𝐈𝐍𝐆:</b> {b_data['name']}\n🔑 Token: <code>{b_data['token'][:15]}...</code>\n\n<b>Status:</b> Running Real ✅", call.message.chat.id, call.message.message_id, reply_markup=markup, parse_mode='HTML')

    elif call.data.startswith("stop_"):
        bot_id = call.data.split("_")[1]
        if user_id in user_sessions and bot_id in user_sessions[user_id]:
            try:
                # Stop the background running child script process completely
                os.kill(user_sessions[user_id][bot_id]['process'].pid, signal.SIGTERM)
                if os.path.exists(user_sessions[user_id][bot_id]['file']): 
                    os.remove(user_sessions[user_id][bot_id]['file'])
            except: 
                pass
            del user_sessions[user_id][bot_id]
            bot.answer_callback_query(call.id, "Bot Stopped and Process Terminated!")
            bot.delete_message(call.message.chat.id, call.message.message_id)

